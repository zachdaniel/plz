#!/usr/bin/env bash
#
# plz — a terminal assistant you pipe through.
#
# Single, portable file. Three roles:
#   plz "<request>"        run the assistant (the engine)
#   plz init <zsh|nu>      print shell glue to wire up pipeline-awareness
#   plz __locate ...       internal: locate this call within a tokenized pipeline
#
# Pipeline context (what you pipe from / to) is computed in the shell glue,
# using each shell's own tokenizer ((z) in zsh, `ast` in nushell), then handed
# to the engine via --piped-from / --piped-to. The engine never parses the
# command line itself.

# ---------------------------------------------------------------------------
# helpers shared by the internal modes
# ---------------------------------------------------------------------------

plz_unquote() {
  local s="$1"
  case "$s" in
    \"*\") s="${s#\"}"; s="${s%\"}" ;;
    \'*\') s="${s#\'}"; s="${s%\'}" ;;
    \`*\`) s="${s#\`}"; s="${s%\`}" ;;
  esac
  printf '%s' "$s"
}

# do_locate: given this call's args ("$@") and a tokenized pipeline on stdin
# (one token per line; a lone "|" is a pipe operator; ";" "&&" "||" "&" start a
# new pipeline group), print exactly three lines:
#   line 1: "ok" or "ambiguous"
#   line 2: piped-from text (may be empty)
#   line 3: piped-to text   (may be empty)
do_locate() {
  local my_args="$*"
  local -a toks=()
  local line
  # `|| [ -n "$line" ]` also captures a final line with no trailing newline
  # (nushell's `str join` produces no trailing newline; zsh's printf does).
  while IFS= read -r line || [ -n "$line" ]; do toks+=("$line"); done

  local -a S_TEXT=() S_ARGS=() S_GROUP=() S_ISPLZ=()
  local group=0 cur_text="" cur_args="" cur_first="" started=0

  _flush() {
    if [ "$started" -eq 1 ]; then
      S_TEXT+=("$cur_text"); S_ARGS+=("$cur_args"); S_GROUP+=("$group")
      if [ "$cur_first" = "plz" ]; then S_ISPLZ+=(1); else S_ISPLZ+=(0); fi
    fi
    cur_text=""; cur_args=""; cur_first=""; started=0
  }

  local tok uq
  for tok in "${toks[@]}"; do
    case "$tok" in
      "|")
        _flush ;;
      ";"|"&&"|"||"|"&"|"|&")
        _flush; group=$((group+1)) ;;
      *)
        if [ "$started" -eq 0 ]; then
          cur_first="$tok"; cur_text="$tok"; started=1
        else
          cur_text="$cur_text $tok"
          uq="$(plz_unquote "$tok")"
          if [ -z "$cur_args" ]; then cur_args="$uq"; else cur_args="$cur_args $uq"; fi
        fi ;;
    esac
  done
  _flush

  local -a cand=()
  local i
  for i in "${!S_TEXT[@]}"; do
    if [ "${S_ISPLZ[$i]}" = "1" ] && [ "${S_ARGS[$i]}" = "$my_args" ]; then
      cand+=("$i")
    fi
  done

  if [ "${#cand[@]}" -eq 0 ]; then
    printf 'ok\n\n\n'; return 0
  fi

  local total=${#S_TEXT[@]}
  local idx g p n fi ti f0="" t0="" amb=0 first=1
  for idx in "${cand[@]}"; do
    g="${S_GROUP[$idx]}"; p=$((idx-1)); n=$((idx+1)); fi=""; ti=""
    if [ "$p" -ge 0 ] && [ "${S_GROUP[$p]}" = "$g" ]; then fi="${S_TEXT[$p]}"; fi
    if [ "$n" -lt "$total" ] && [ "${S_GROUP[$n]}" = "$g" ]; then ti="${S_TEXT[$n]}"; fi
    if [ "$first" -eq 1 ]; then f0="$fi"; t0="$ti"; first=0
    elif [ "$fi" != "$f0" ] || [ "$ti" != "$t0" ]; then amb=1; fi
  done

  if [ "$amb" -eq 1 ]; then printf 'ambiguous\n\n\n'; return 0; fi
  printf 'ok\n%s\n%s\n' "$f0" "$t0"
}

# ---------------------------------------------------------------------------
# init: print shell glue
# ---------------------------------------------------------------------------

plz_init() {
  case "${1:-}" in
    zsh)
      cat <<'ZSH_GLUE'
# plz zsh integration.  Add to ~/.zshrc:  eval "$(plz init zsh)"
typeset -g __PLZ_CMD=""
autoload -Uz add-zsh-hook 2>/dev/null
__plz_preexec() { __PLZ_CMD="$1"; }   # captured per command, NOT exported
add-zsh-hook preexec __plz_preexec 2>/dev/null

plz() {
  emulate -L zsh
  local s="" f="" t=""
  if [[ -n "$__PLZ_CMD" ]]; then
    local -a toks
    toks=( ${(z)__PLZ_CMD} )
    { IFS= read -r s; IFS= read -r f; IFS= read -r t; } < <(
      printf '%s\n' "${toks[@]}" | command plz __locate "$@"
    )
  fi
  if [[ "$s" == "ambiguous" ]]; then
    print -u2 "plz: ambiguous pipeline — two identical 'plz' calls with different neighbors. Vary one prompt to disambiguate."
    return 1
  fi
  command plz --shell zsh ${__PLZ_CMD:+--pipeline "$__PLZ_CMD"} ${f:+--piped-from "$f"} ${t:+--piped-to "$t"} "$@"
}
ZSH_GLUE
      ;;
    nu|nushell)
      cat <<'NU_GLUE'
# plz nushell integration.  Generate + source once, e.g.:
#   plz init nu | save -f ($nu.default-config-dir | path join plz.nu)
#   # then add to config.nu:   source plz.nu
$env.config.hooks.pre_execution = (
  $env.config.hooks.pre_execution? | default [] | append {||
    # stored as a record so it is NOT exported to child processes (no leak
    # into nested scripts); still readable by the `plz` command below.
    $env.PLZ = { cmd: (commandline) }
  }
)

# Resolve the engine option list from the captured command line. Reads only
# $env.PLZ (never $in), so it can run without disturbing the piped input.
# Errors if the pipeline is ambiguous (two identical plz calls, different
# neighbors).
def __plz_opts [...rest] {
  mut opts = ["--shell" "nu"]
  let cmdline = ($env.PLZ?.cmd? | default "")
  if ($cmdline | is-not-empty) {
    $opts = ($opts | append ["--pipeline" $cmdline])
    let toks = (
      ast $cmdline --flatten --json | from json
      | uniq-by span
      | each {|x| if $x.shape == "shape_pipe" { "|" } else { $x.content } }
    )
    let out = ($toks | str join "\n" | ^plz __locate ...$rest | split row "\n")
    let s = ($out | get 0? | default "")
    let f = ($out | get 1? | default "")
    let t = ($out | get 2? | default "")
    if $s == "ambiguous" {
      error make {msg: "plz: ambiguous pipeline — two identical 'plz' calls with different neighbors. Vary one prompt to disambiguate."}
    }
    if ($f | is-not-empty) { $opts = ($opts | append ["--piped-from" $f]) }
    if ($t | is-not-empty) { $opts = ($opts | append ["--piped-to" $t]) }
  }
  $opts
}

def --wrapped plz [...rest] {
  # Inspect the input type without consuming/collecting $in (describe
  # --no-collect is non-destructive). NOTE: after that, $in only survives if used
  # at the TOP LEVEL — using it inside an `if` branch yields null. So we select a
  # transform CLOSURE with the `if` (no $in in the branch) and pipe $in through
  # it exactly once, at top level. Structured nushell data (table/record/list)
  # becomes JSON so the model gets named fields instead of an ASCII-art table;
  # plain text / byte streams pass through untouched and keep streaming.
  let ty = ($in | describe --no-collect)
  let structured = (($ty | str starts-with "table") or ($ty | str starts-with "record") or ($ty | str starts-with "list"))
  let opts = (__plz_opts ...$rest)

  # Find the downstream command (if any) so we can decide whether to emit a
  # nushell value or plain text. We render structured output (JSON -> value)
  # when plz is LAST, or when it feeds a native nushell command (where/select/
  # sort-by/...). We keep TEXT when it feeds an external (jq/grep) or another plz.
  let ti = ($opts | enumerate | where item == "--piped-to" | get index.0? | default (-1))
  let downstream = (if $ti >= 0 { $opts | get ($ti + 1) } else { "" })
  let dw = ($downstream | str trim | split row " " | get 0? | default "")
  let dtype = (if ($dw | is-empty) { "" } else { (try { which $dw | get type | first } catch { "external" }) })
  let render = (($downstream | is-empty) or ($dtype in ["keyword" "built-in"]))

  let extra = (
    (if $structured { ["--stdin-json" "--input-shape" $ty] } else { [] })
    | append (if $render { ["--render-json"] } else { [] })
  )
  # in-closure: structured input -> JSON. out-closure: when rendering, parse the
  # JSON output into a real nushell value (table) so the user / next nushell
  # command gets structured data; fall back to raw text if it isn't JSON.
  $in
  | do (if $structured { {|| to json -r } } else { {|| $in } })
  | ^plz ...$opts ...$extra ...$rest
  | do (if $render { {|| let o = $in; try { $o | from json } catch { try { $o | from json --objects } catch { $o } } } } else { {|| $in } })
}
NU_GLUE
      ;;
    *)
      echo "usage: plz init <zsh|nu>" >&2
      return 1
      ;;
  esac
}

# ---------------------------------------------------------------------------
# transform: a pure LLM filter — reads stdin, applies natural-language
# instructions, writes ONLY the transformed result. Generated commands can pipe
# through this when a deterministic tool can't reliably structure the data.
# ---------------------------------------------------------------------------

do_transform() {
  local instructions="$*"
  claude --dangerously-skip-permissions -p "Apply this transformation to the input on stdin and output ONLY the result — no explanation, no preamble, no markdown code fences: $instructions" \
    2> >(grep -v "claude.ai connectors are disabled" >&2)
}

# ---------------------------------------------------------------------------
# dispatch
# ---------------------------------------------------------------------------

if [ "${1:-}" = "__locate" ]; then shift; do_locate "$@"; exit $?; fi
if [ "${1:-}" = "init" ]; then shift; plz_init "$@"; exit $?; fi
if [ "${1:-}" = "transform" ]; then shift; do_transform "$@"; exit $?; fi

# ===========================================================================
# engine
# ===========================================================================

before_plz=""
after_plz=""
shell_name=""
user_input=""
stdin_json=false
input_shape=""
render_json=false
full_pipeline=""
found_positional=false
verbose=false
args=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --piped-from)  before_plz="$2"; shift 2 ;;
    --piped-to)    after_plz="$2";  shift 2 ;;
    --shell)       shell_name="$2"; shift 2 ;;
    --stdin-json)  stdin_json=true; shift ;;
    --input-shape) input_shape="$2"; shift 2 ;;
    --render-json) render_json=true; shift ;;
    --pipeline)    full_pipeline="$2"; shift 2 ;;
    --verbose|-v) verbose=true; shift ;;
    *)
      if [[ "$1" != -* ]] && [[ "$found_positional" == false ]]; then
        user_input="<user_input>$1</user_input>"
        found_positional=true
      else
        args+=("$1")
      fi
      shift ;;
  esac
done

if [ -z "$shell_name" ]; then
  shell_name=$(ps -o comm= -p "$PPID" 2>/dev/null | sed 's#.*/##; s/^-//')
  [ -z "$shell_name" ] && shell_name=$(basename "${SHELL:-sh}")
fi

# PLZ_DEBUG: show the resolved pipeline context and exit without reading stdin
# or calling claude. Handy for confirming pipeline detection.
if [ -n "${PLZ_DEBUG:-}" ]; then
  {
    echo "plz debug:"
    echo "  shell:      $shell_name"
    echo "  piped_from: $before_plz"
    echo "  piped_to:   $after_plz"
    echo "  request:    $user_input"
  } >&2
  exit 0
fi

prompt="You are plz: you turn a request into ONE shell command and nothing else.
The command is run via bash. If input is piped in, it arrives on the command's stdin and the command's stdout is the result. Write POSIX/bash syntax, and read from stdin rather than assuming the input is small or finite.

The user's interactive shell is: $shell_name."

if [ -n "$full_pipeline" ]; then
  prompt="$prompt

You are ONE stage in this shell pipeline:
<pipeline>
$full_pipeline
</pipeline>
You are responsible ONLY for the 'plz' step described by the request below; the other stages run separately, so do not redo their work. But use the WHOLE pipeline to understand intent and to stay consistent with it — in particular, if a later stage references specific field/column names (e.g. 'where Username', 'select Foo'), produce those exact names, and honor naming implied by earlier steps' requests."
fi

if [ -n "$before_plz" ]; then
  prompt="$prompt

The stdin input is produced by:
<piped_from>
$before_plz
</piped_from>"
fi

if [ -n "$after_plz" ]; then
  prompt="$prompt

Your command's stdout is piped directly into:
<piped_to>
$after_plz
</piped_to>
So the command MUST emit exactly what '$after_plz' expects and nothing else — e.g. valid JSON for jq, raw columns for awk/sed, matchable text for grep — never prose. If the input is not already in that shape, your command must TRANSFORM it into that shape (e.g. parse each matching line into a JSON object when piping to jq) — do not just filter and pass the raw text through."
fi

# Peek only the first PREVIEW_BYTES bytes of stdin as a format hint. The rest of
# the stream stays untouched in the pipe so the generated command can consume it
# live — this is what lets `some_logger | plz "..."` stream instead of block.
PREVIEW_BYTES="${PLZ_PREVIEW_BYTES:-1000}"
has_stdin=false
peekfile=""
if [ ! -t 0 ]; then
  has_stdin=true
  peekfile=$(mktemp "${TMPDIR:-/tmp}/plz.peek.XXXXXX")
  trap 'rm -f "$peekfile"' EXIT
  # dd bs=1 does single-byte reads, so it consumes EXACTLY PREVIEW_BYTES and
  # leaves the rest of the stream in the pipe. (head -c over-reads and would
  # discard the remainder, truncating the input the command sees.)
  dd bs=1 count="$PREVIEW_BYTES" > "$peekfile" 2>/dev/null

  if [ "$stdin_json" = true ]; then
    prompt="$prompt

The piped input is JSON, serialized from the upstream command's structured ${shell_name} output${input_shape:+ of shape: $input_shape}. Treat stdin as JSON (e.g. parse with jq, referencing those columns/fields). First $PREVIEW_BYTES bytes (a format hint ONLY; your command receives the full input):
<input_preview>
$(cat "$peekfile")
</input_preview>"
  else
    prompt="$prompt

The first $PREVIEW_BYTES bytes of stdin (a format hint ONLY — your command receives the full, possibly unbounded stream):
<input_preview>
$(cat "$peekfile")
</input_preview>"
  fi
fi

if [ "$render_json" = true ]; then
  prompt="$prompt

Your stdout will be parsed as JSON by nushell and shown to the user as a TABLE (or fed to a nushell command). Emit ONE single JSON value. For multiple records, that MUST be a single JSON ARRAY of flat objects with the SAME keys in each — e.g. [{\"k\":1},{\"k\":2}]. Do NOT emit newline-delimited JSON or one object per line (no streaming jq with a trailing '.[]', no one-object-per-line). Use a single JSON object for one record, or a JSON scalar only for a genuine single value. JSON only — no prose."
fi

prompt="$prompt

For transformations that need real language understanding — turning unstructured or natural-language text into structured data, summarizing, classifying, fuzzy extraction — your command can pipe through 'plz transform \"<instructions>\"', an LLM filter that reads stdin and writes ONLY the transformed result. Prefer plain tools (grep/sed/awk/jq/cut) whenever they'll do the job reliably; they are faster and they stream. Reach for 'plz transform' only when a regex or parser would be brittle (it reads its whole input, so don't use it on unbounded streams).

Reply with ONLY one of these — no explanation, no preamble, no markdown fences:
<cmd>the single shell command to run</cmd>
<error>a short reason you cannot produce a command</error>

Whatever the request — extract, filter, transform, format, fetch, even \"give me a command to ...\" — answer with the <cmd> that does it. Its own stdout is the result. The command MUST handle the ENTIRE input — every line/record/item it contains, not just the first one (loop or operate over all of them).
"

if [ -n "$user_input" ]; then
  args+=("-p" "$user_input")
fi

get_claude_response() {
  local prompt_to_send="$1"
  echo "$prompt_to_send" | claude --dangerously-skip-permissions "${args[@]}" \
    2> >(grep -v "claude.ai connectors are disabled" >&2)
}

# Run the model's command against the live stream: replay the peeked bytes, then
# hand the rest of stdin straight through so output streams (nothing buffered).
run_generated_cmd() {
  local cmd="$1"
  cmd=$(echo "$cmd" | sed "s/sed '\\([0-9]*i\\\\\\)\\([^']*\\)'/sed '\\1\\\n\\2'/g")
  if [ "$verbose" = true ]; then echo "→ Running: $cmd" >&2; fi
  if [ "$has_stdin" = true ]; then
    # Guarantee the input ends with a newline. nushell pipes strings WITHOUT a
    # trailing newline, which makes the common `while read` loop silently drop
    # the last (unterminated) item. `awk '{print}'` adds the missing final
    # newline without doubling an existing one; fflush keeps it streaming.
    { cat "$peekfile"; cat; } | awk '{print; fflush()}' | bash -c "$cmd"
  else
    bash -c "$cmd"
  fi
}

handle_response() {
  local response="$1"
  local current_prompt="$2"
  local retry_count="${3:-0}"

  # A command — run it and pass its exit code through. Output already streamed.
  if echo "$response" | grep -q "<cmd>"; then
    # Take everything after the first <cmd>, then cut at the first terminator.
    # The nested model sometimes appends its own tool-call tags (</invoke> etc.)
    # instead of a clean </cmd>, so we stop at those too and strip any residual
    # markup before it can reach the shell.
    local cmd="${response#*<cmd>}"
    cmd="${cmd%%</cmd>*}"
    cmd="${cmd%%</invoke>*}"
    cmd="${cmd%%</parameter>*}"
    cmd="${cmd%%</function_calls>*}"
    cmd=$(printf '%s' "$cmd" | sed -E 's#</?(cmd|invoke|parameter|function_calls|function)[^>]*>##g; s#</?antml:[A-Za-z_]+[^>]*>##g')
    cmd="${cmd#"${cmd%%[![:space:]]*}"}"   # trim leading whitespace/newlines
    cmd="${cmd%"${cmd##*[![:space:]]}"}"   # trim trailing whitespace/newlines
    if [ -n "$cmd" ]; then
      run_generated_cmd "$cmd"
      exit $?
    fi
  fi

  # An explicit refusal.
  if echo "$response" | grep -q "<error>"; then
    local error_message=$(echo "$response" | sed -n '/<error>/,/<\/error>/p' | sed '1s/^.*<error>//' | sed '$s/<\/error>.*$//' | sed '/^[[:space:]]*$/d')
    if [ -n "$error_message" ]; then
      echo -n "$error_message" >&2
      exit 1
    fi
  fi

  # Neither — the model added prose/fences. Re-ask (nothing has been consumed).
  if [ "$retry_count" -ge 2 ]; then
    echo "plz: couldn't get a command from the model." >&2
    exit 1
  fi
  local retry_prompt="$current_prompt

Your previous reply was not a single tagged command:
$response

Reply again with ONLY <cmd>…</cmd> or <error>…</error> and no other text."
  local retry_response=$(get_claude_response "$retry_prompt")
  handle_response "$retry_response" "$retry_prompt" $((retry_count + 1))
}

response=$(get_claude_response "$prompt")
handle_response "$response" "$prompt"
